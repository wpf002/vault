# Copy to .env (gitignored) and fill in. The API degrades gracefully when a
# section is missing: no Stripe keys → checkout returns a configuration error,
# no Anthropic key → /ai/* returns 503 (or set AI_PROVIDER=stub for dev).

# --- Required ---
DATABASE_URL=postgresql://vault:vault@localhost:5432/vault?schema=public
AUTH_SECRET=            # shared HS256 secret with the web app's NextAuth

# --- Billing (Phase 2 — wired, activates when set) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=  # from `stripe listen` in dev, dashboard endpoint in prod
STRIPE_PRICE_SUBSCRIPTION=  # price ID for the all-access subscription

# --- AI proxy (Phase 7) ---
ANTHROPIC_API_KEY=
# AI_PROVIDER=stub      # deterministic dev/CI provider, no key or spend needed
# AI_MODEL=claude-haiku-4-5-20251001
# PREVIEW_AI_CALLS=5    # free AI calls per module for unentitled users
# AI_RATE_LIMIT_PER_MIN=20

# --- Server ---
# API_PORT=4000
# ADMIN_EMAILS=you@example.com  # comma-separated; grants /admin/* access (Phase 8)

# --- Observability (Phase 9) ---
# ALERT_WEBHOOK_URL=   # any {"text": ...} webhook (Slack/Discord/ntfy) — pages on 5xx,
#                      # Stripe webhook failures, and AI provider outages (5-min dedupe)
# CORS_ORIGIN=https://yourdomain.com  # comma-separated; unset = permissive (dev only)
# RATE_LIMIT_PER_MIN=120              # per-IP, all routes except /health
